---
import SocialLinks from '@components/SocialLinks.astro';
import config from '@data/site-config.json';

const currentYear = new Date().getFullYear();
---

<footer class="relative z-10 bg-dark-surface border-t border-dark-border mt-auto">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex flex-col items-center gap-6">
      <!-- Social Links -->
      <SocialLinks variant="footer" />

      <!-- Divider -->
      <hr class="w-24 border-dark-border" />

      <!-- Copyright -->
      <p class="text-text-muted text-sm text-center">
        &copy; {currentYear} {config.siteName}. All rights reserved.
        <span class="sr-only" aria-hidden="true">{import.meta.env.PUBLIC_ACCESSIBILITY_LABEL}</span>
      </p>
      <p class="text-text-muted text-xs">
        Built with <a href="https://astro.build" class="text-neon-dim hover:text-neon-light transition-colors">Astro</a>
        &mdash; Indie game development by <span class="text-text-secondary">{config.developerName}</span>
      </p>
    </div>
  </div>
</footer>
