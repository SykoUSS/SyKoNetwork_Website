---
export interface PatreonPost {
  id: string;
  title: string;
  content: string;
  published_at: string;
  url: string;
  is_public: boolean;
  thumbnail_url: string | null;
  image_url: string | null;
}

const { post } = Astro.props as { post: PatreonPost };

// Format date
const date = new Date(post.published_at);
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

// Strip HTML tags for excerpt
const stripHtml = (html: string): string => {
  return html.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
};

const excerpt = stripHtml(post.content).slice(0, 200) + (stripHtml(post.content).length > 200 ? '...' : '');

// Ensure Patreon URLs are absolute
const postUrl = post.url.startsWith('http') ? post.url : `https://www.patreon.com${post.url}`;

// Determine if we have a background image
const hasBackgroundImage = !!post.image_url;

// Prepend base path for local images (Astro requires base for public assets)
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const backgroundImageSrc = post.image_url?.startsWith('/') ? `${basePath}${post.image_url}` : post.image_url;
---

<article class={`relative overflow-hidden rounded-xl border transition-all duration-300 hover:scale-[1.01] ${hasBackgroundImage ? 'border-dark-border/60 hover:border-neon/20' : 'bg-dark-card border-dark-border hover:border-neon/20'}`}>
  <!-- Blurred background image -->
  {hasBackgroundImage && (
    <div class="absolute inset-0 z-0">
      <img
        src={backgroundImageSrc}
        alt=""
        class="w-full h-full object-cover scale-110 blur-md brightness-[0.6] saturate-[0.7]"
        loading="lazy"
        aria-hidden="true"
        onerror="this.onerror=null; this.parentElement.style.display='none'; this.closest('article').classList.add('bg-dark-card');"
      />
      <!-- Gradient overlay for readability -->
      <div class="absolute inset-0 bg-gradient-to-b from-dark-bg/40 via-dark-bg/60 to-dark-bg/85"></div>
    </div>
  )}

  <div class={`relative z-10 p-5 sm:p-6 ${hasBackgroundImage ? '' : ''}`}>
    <!-- Header -->
    <div class="flex items-start justify-between gap-4 mb-3">
      <h3 class="text-lg font-bold text-text-primary leading-snug">
        {post.title}
      </h3>
      {!post.is_public && (
        <span class="shrink-0 inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-semibold bg-neon/10 text-neon-light border border-neon/20" title="Patron-only content">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          PATRON-ONLY
        </span>
      )}
    </div>

    <!-- Date -->
    <time datetime={post.published_at} class="text-sm text-text-muted block mb-3">
      {formattedDate}
    </time>

    <!-- Content -->
    {post.is_public ? (
      <p class="text-sm text-text-secondary leading-relaxed mb-4">
        {excerpt}
      </p>
    ) : (
      <div class="bg-dark-surface/80 rounded-lg p-4 mb-4 text-center backdrop-blur-sm">
        <p class="text-sm text-text-muted">
          🔒 This post is exclusive to Patreon members.
        </p>
      </div>
    )}

    <!-- Thumbnail (if available) -->
    {post.thumbnail_url && (
      <div class="mb-4 rounded-lg overflow-hidden thumbnail-container">
        <img
          src={post.thumbnail_url}
          alt={`${post.title} thumbnail`}
          class="w-full h-40 object-cover opacity-80 hover:opacity-100 transition-opacity"
          loading="lazy"
          referrerpolicy="no-referrer"
          onerror="this.onerror=null; this.closest('.thumbnail-container').style.display='none';"
        />
      </div>
    )}

    <!-- Link -->
    <a
      href={postUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 text-sm font-medium text-neon-light hover:text-neon-glow transition-colors"
    >
      {post.is_public ? 'Read on Patreon' : 'Unlock on Patreon'}
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  </div>
</article>

<script>
  // Hide stalled external images after 8 seconds
  function initThumbnailFallback() {
    document.querySelectorAll('.thumbnail-container img').forEach(img => {
      const container = img.closest('.thumbnail-container');
      if (!container) return;
      setTimeout(() => {
        if (img.naturalWidth === 0 && !img.complete) {
          container.style.display = 'none';
        }
      }, 8000);
    });
  }
  // Run on initial load and after ViewTransitions page swaps
  initThumbnailFallback();
  document.addEventListener('astro:after-swap', initThumbnailFallback);
</script>
