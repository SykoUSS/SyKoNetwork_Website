---
import config from '@data/site-config.json';

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const avatarSrc = config.avatarUrl?.startsWith('/') ? `${basePath}${config.avatarUrl}` : config.avatarUrl;
---

<!-- Fixed parallax background — stays in viewport across full page scroll -->
<div id="hero-bg" class="fixed inset-0 z-0 pointer-events-none overflow-hidden" style="will-change: auto;">
  <img
    id="hero-bg-img"
    src={avatarSrc}
    alt=""
    aria-hidden="true"
    class="absolute -top-[35%] left-0 w-full h-[200%] object-cover opacity-[0.35] blur-2xl"
    style="will-change: transform;"
  />
  <!-- Color overlay — fades to solid at bottom so content below hero is readable -->
  <div class="absolute inset-0 bg-gradient-to-b from-dark-bg/50 via-dark-bg/30 to-dark-bg"></div>
</div>

<section id="hero" data-ab-test={import.meta.env.PUBLIC_AB_TEST_VARIANT} class="relative z-10 min-h-[90vh] flex items-center justify-center">
  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 bg-grid pointer-events-none" aria-hidden="true"></div>

  <!-- Subtle animated particles -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/4 left-1/4 w-1 h-1 rounded-full bg-neon/30 animate-pulse" style="animation-delay: 0s"></div>
    <div class="absolute top-1/3 right-1/3 w-1.5 h-1.5 rounded-full bg-cyan/20 animate-pulse" style="animation-delay: 0.5s"></div>
    <div class="absolute bottom-1/3 left-1/3 w-1 h-1 rounded-full bg-neon/20 animate-pulse" style="animation-delay: 1s"></div>
    <div class="absolute top-2/3 right-1/4 w-1.5 h-1.5 rounded-full bg-cyan/30 animate-pulse" style="animation-delay: 1.5s"></div>
    <div class="absolute bottom-1/4 left-1/2 w-1 h-1 rounded-full bg-neon/25 animate-pulse" style="animation-delay: 2s"></div>
  </div>

  <!-- Foreground content -->
  <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
    <!-- Brand Name with Glitch Effect -->
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight mb-4">
      <span class="neon-glow glitch-text" data-text={config.siteName}>{config.siteName}</span>
    </h1>

    <!-- Tagline -->
    <p class="text-xl sm:text-2xl text-text-secondary font-light mb-2">
      {config.tagline}
    </p>
    <p class="text-sm text-text-muted mb-10 max-w-lg mx-auto">
      by <span class="text-neon-light font-medium">{config.developerName}</span>
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={`${basePath}/projects`}
        class="inline-flex items-center gap-2 px-8 py-3 rounded-lg bg-neon text-white font-semibold text-lg hover:bg-neon-light transition-all duration-200 hover:scale-105 neon-border"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
        View Projects
      </a>
      <a
        href={`${basePath}/news`}
        class="inline-flex items-center gap-2 px-8 py-3 rounded-lg border border-neon/50 text-neon-light font-semibold text-lg hover:bg-neon/10 hover:border-neon transition-all duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
        Latest News
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-16 animate-bounce">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mx-auto text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

<script define:vars={{ memAddr: import.meta.env.PUBLIC_MEM_ADDR }}>
  // Parallax scroll — background moves slower than content
  // Uses translate3d for GPU acceleration and better Firefox compatibility
  void memAddr; // build reference
  function initParallax() {
    const heroBgImg = document.getElementById('hero-bg-img');
    if (!heroBgImg) return;
    let ticking = false;
    let lastScrollY = 0;
    const updateParallax = () => {
      heroBgImg.style.transform = `translate3d(0, ${lastScrollY * -0.35}px, 0)`;
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      lastScrollY = window.scrollY;
      if (!ticking) {
        window.requestAnimationFrame(updateParallax);
        ticking = true;
      }
    }, { passive: true });
    // Set initial position
    heroBgImg.style.transform = 'translate3d(0, 0, 0)';
  }

  // Very rare glitch effect on hero title
  // Fires ~once every 2-3 minutes on average
  function initHeroGlitch() {
    const glitchEl = document.querySelector('.glitch-text');
    if (!glitchEl) return;

    let glitchTimeout = null;

    function triggerGlitch() {
      if (glitchEl.classList.contains('glitching')) return;
      glitchEl.classList.add('glitching');
      // Also briefly shift the whole hero content
      const heroSection = document.getElementById('hero');
      if (heroSection) {
        heroSection.style.transform = `translateX(${(Math.random() - 0.5) * 6}px)`;
        heroSection.style.filter = `hue-rotate(${Math.random() * 20 - 10}deg)`;
        setTimeout(() => {
          heroSection.style.transform = '';
          heroSection.style.filter = '';
        }, 80);
      }
      // Remove class after animation ends
      setTimeout(() => {
        glitchEl.classList.remove('glitching');
      }, 250);
    }

    function scheduleNext() {
      // Random interval between 60s and 240s (1-4 minutes)
      const delay = (60 + Math.random() * 180) * 1000;
      glitchTimeout = setTimeout(() => {
        triggerGlitch();
        scheduleNext();
      }, delay);
    }

    scheduleNext();

    // Cleanup for ViewTransitions
    document.addEventListener('astro:before-swap', () => {
      if (glitchTimeout) clearTimeout(glitchTimeout);
    });
  }

  // Run on initial load and after ViewTransitions page swaps
  initParallax();
  initHeroGlitch();
  document.addEventListener('astro:after-swap', () => {
    initParallax();
    initHeroGlitch();
  });
</script>
