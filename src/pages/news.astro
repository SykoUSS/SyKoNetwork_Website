---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeader from '@components/SectionHeader.astro';
import NewsFeed from '@components/NewsFeed.astro';
import Avatar from '@components/Avatar.astro';
import posts from '@data/patreon-posts.json';
import config from '@data/site-config.json';
---

<BaseLayout title="News" description={`Latest updates and posts from ${config.developerName} on Patreon.`}>
  <div class="py-16 sm:py-20 px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto">
    <!-- Page Title -->
    <div class="text-center mb-16">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">
        <span class="neon-glow">News &amp; Updates</span>
      </h1>
      <p class="text-text-muted text-lg max-w-2xl mx-auto">
        The latest from {config.developerName}. For exclusive content and early access, join the community on Patreon.
      </p>
    </div>

    <!-- Patreon CTA Banner -->
    <div class="mb-12 bg-dark-card border border-neon/20 rounded-xl p-6 sm:p-8 flex flex-col sm:flex-row items-center gap-6">
      <div class="shrink-0">
        <Avatar size="md" class="ring-2 ring-neon/30" />
      </div>
      <div class="flex-1 text-center sm:text-left">
        <p class="text-text-primary font-semibold text-lg">Support {config.developerName} on Patreon</p>
        <p class="text-text-muted text-sm mt-1">Get early access to posts, exclusive content, and behind-the-scenes updates.</p>
      </div>
      <a
        href={config.patreonUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 inline-flex items-center gap-2 px-6 py-2.5 rounded-lg bg-neon text-white font-semibold hover:bg-neon-light transition-all duration-200 hover:scale-105"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M15.386.524c-4.764 0-8.64 3.876-8.64 8.64 0 4.75 3.876 8.613 8.64 8.613 4.75 0 8.614-3.864 8.614-8.613C24 4.4 20.136.524 15.386.524M.004 23.537h4.22V.524H.004z" />
        </svg>
        Join on Patreon
      </a>
    </div>

    <!-- Posts Feed -->
    <SectionHeader
      title="All Updates"
      subtitle="Sorted newest first — public and patron-only posts"
    />
    <NewsFeed posts={posts} emptyMessage="No updates available yet. Check back soon or follow on Patreon for the latest news!" />

    <!-- Bottom CTA -->
    {posts.length > 0 && (
      <div class="text-center mt-12 pt-8 border-t border-dark-border">
        <p class="text-text-muted text-sm mb-4">Want to see more? Join the Patreon community for exclusive content.</p>
        <a
          href={config.patreonUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg border border-neon/50 text-neon-light font-medium hover:bg-neon/10 hover:border-neon transition-all"
        >
          Visit Patreon
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    )}
  </div>
</BaseLayout>
