---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import ProjectCard from '@components/ProjectCard.astro';
import projects from '@data/projects.json';
import config from '@data/site-config.json';

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const activeProjects = projects.filter((p) => p.status === 'active' || p.status === 'coming-soon');
---

<BaseLayout title="Home" description={`${config.siteName} — ${config.tagline}. ${config.description}`}>
  <!-- Hero -->
  <Hero />

  <!-- Featured Projects — Central Showpiece -->
  <section class="relative z-10 glass-card rounded-2xl py-20 sm:py-28 px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto my-8 sm:my-12">
    <!-- Section header with glow accent -->
    <div class="text-center mb-16">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-neon/10 text-neon-light border border-neon/20 mb-4">
        WHAT WE'RE BUILDING
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight mb-4">
        <span class="neon-glow">Featured Projects</span>
      </h2>
      <p class="text-text-muted text-lg max-w-2xl mx-auto">
        The latest indie game projects and experiments from SyKoNetwork.
        <br class="hidden sm:block" />
        Follow along as new adventures take shape.
      </p>
      <hr class="w-20 mx-auto mt-6 border-neon/30" />
    </div>

    {activeProjects.length > 0 ? (
      <div class="flex flex-col gap-8 stagger-children">
        {activeProjects.map((project, index) => (
          <ProjectCard project={project} variant="featured" index={index} />
        ))}
      </div>
    ) : (
      <div class="text-center py-20 bg-dark-card rounded-2xl border border-dark-border">
        <div class="mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto text-neon-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
          </svg>
        </div>
        <p class="text-text-muted text-xl font-medium">Something new is brewing...</p>
        <p class="text-text-muted text-sm mt-2">Stay tuned for exciting announcements!</p>
      </div>
    )}

    <!-- CTA to full projects page -->
    <div class="text-center mt-14">
      <a
        href={`${basePath}/projects`}
        class="inline-flex items-center gap-2 px-8 py-3 rounded-lg bg-neon text-white font-semibold text-lg hover:bg-neon-light transition-all duration-200 hover:scale-105 neon-border"
      >
        View All Projects
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Spacer between content and footer -->
  <div class="relative z-10 h-24"></div>
</BaseLayout>
