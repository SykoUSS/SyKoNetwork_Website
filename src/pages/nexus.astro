---
import BaseLayout from '@layouts/BaseLayout.astro';
import argSecrets from '@data/arg-secrets.json';

const systemAscii = argSecrets.systemAscii.replace(/\\n/g, '\n');
---

<BaseLayout title="System" description="">
  <div class="system-notice">
    <div class="scan-lines" aria-hidden="true"></div>

    <div class="system-container">
      <div class="system-header">
        <h1 class="system-title">
          <span class="glitch-system" data-text={argSecrets.systemTitle}>{argSecrets.systemTitle}</span>
        </h1>
        <p class="system-subtitle">{argSecrets.systemSubtitle}</p>
      </div>

      <div class="system-transmission">
        <pre class="system-text">{systemAscii}</pre>
      </div>

      <div class="system-footer">
        <p class="system-hint">{argSecrets.systemClue}</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .system-notice {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background: radial-gradient(ellipse at 50% 50%, rgba(239, 68, 68, 0.04) 0%, transparent 70%);
  }

  .scan-lines {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 100;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.06) 2px,
      rgba(0, 0, 0, 0.06) 4px
    );
  }

  .system-container {
    position: relative;
    z-index: 10;
    max-width: 600px;
    width: 100%;
    text-align: center;
  }

  .system-header {
    margin-bottom: 2rem;
  }

  .system-title {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: 900;
    letter-spacing: 0.2em;
    margin-bottom: 0.5rem;
  }

  .glitch-system {
    color: #f87171;
    text-shadow: 0 0 20px rgba(248, 113, 113, 0.4), 0 0 40px rgba(248, 113, 113, 0.15);
    position: relative;
    display: inline-block;
  }

  .glitch-system::before,
  .glitch-system::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: inherit;
    overflow: hidden;
    opacity: 0.3;
  }

  .glitch-system::before {
    color: #ef4444;
    z-index: -1;
    animation: system-r 4s infinite linear alternate-reverse;
    clip-path: polygon(0 0, 100% 0, 100% 40%, 0 40%);
  }

  .glitch-system::after {
    color: #fbbf24;
    z-index: -2;
    animation: system-b 3.5s infinite linear alternate-reverse;
    clip-path: polygon(0 60%, 100% 60%, 100% 100%, 0 100%);
  }

  @keyframes system-r {
    0%, 90%, 100% { transform: translate(0); }
    92% { transform: translate(-3px, 1px); }
    94% { transform: translate(2px, -1px); }
    96% { transform: translate(0); }
  }

  @keyframes system-b {
    0%, 88%, 100% { transform: translate(0); }
    90% { transform: translate(3px, 0); }
    93% { transform: translate(-2px, 1px); }
    95% { transform: translate(0); }
  }

  .system-subtitle {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: #f87171;
    opacity: 0.6;
  }

  .system-transmission {
    margin-bottom: 2rem;
    display: flex;
    justify-content: center;
  }

  .system-text {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    line-height: 1.6;
    color: #fca5a5;
    background: rgba(8, 8, 13, 0.9);
    border: 1px solid rgba(248, 113, 113, 0.15);
    border-radius: 0.5rem;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    white-space: pre;
    box-shadow: 0 0 30px rgba(248, 113, 113, 0.03), inset 0 0 30px rgba(248, 113, 113, 0.01);
    display: inline-block;
    text-align: left;
  }

  @media (min-width: 640px) {
    .system-text {
      font-size: 0.75rem;
      padding: 1.5rem 2rem;
    }
  }

  .system-footer {
    margin-top: 1rem;
  }

  .system-hint {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
    opacity: 0.4;
  }
</style>